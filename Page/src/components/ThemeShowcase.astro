---
const themes = [
  { name: 'Warm Cream', bg: '#F4F2D9', sidebar: '#EDEBCF', text: '#1a1a2e', accent: '#6366f1', muted: '#5c5a44', code: '#EBE9CE' },
  { name: 'Tokyo Night', bg: '#1a1b26', sidebar: '#16161e', text: '#c0caf5', accent: '#7aa2f7', muted: '#565f89', code: '#24283b' },
  { name: 'Solarized Light', bg: '#fdf6e3', sidebar: '#eee8d5', text: '#657b83', accent: '#268bd2', muted: '#93a1a1', code: '#eee8d5' },
  { name: 'Nord', bg: '#2e3440', sidebar: '#272c36', text: '#d8dee9', accent: '#88c0d0', muted: '#7b88a1', code: '#3b4252' },
  { name: 'Monokai', bg: '#272822', sidebar: '#1e1f1c', text: '#f8f8f2', accent: '#a6e22e', muted: '#75715e', code: '#3e3d32' },
];
---

<section id="themes" class="themes section">
  <div class="container">
    <h2 class="section-title themes__title" data-animate>Make it yours</h2>
    <p class="section-subtitle themes__subtitle" data-animate style="--delay: 0.1s">
      5 built-in themes, plus unlimited custom themes with a live color picker.
    </p>

    <div class="themes__grid" data-animate style="--delay: 0.15s">
      {themes.map((t) => (
        <div class="theme-card">
          <div class="theme-preview" style={`--t-bg: ${t.bg}; --t-sidebar: ${t.sidebar}; --t-text: ${t.text}; --t-accent: ${t.accent}; --t-muted: ${t.muted}; --t-code: ${t.code};`}>
            <div class="theme-preview__sidebar">
              <div class="theme-preview__dot" style={`background: ${t.accent}`}></div>
              <div class="theme-preview__tab"></div>
              <div class="theme-preview__tab active"></div>
              <div class="theme-preview__tab"></div>
            </div>
            <div class="theme-preview__editor">
              <div class="theme-preview__line heading"></div>
              <div class="theme-preview__line" style="width: 90%"></div>
              <div class="theme-preview__line" style="width: 75%"></div>
              <div class="theme-preview__line" style="width: 60%"></div>
              <div class="theme-preview__code">
                <div class="theme-preview__line code-line" style="width: 80%"></div>
                <div class="theme-preview__line code-line" style="width: 65%"></div>
              </div>
              <div class="theme-preview__line" style="width: 85%"></div>
            </div>
          </div>
          <span class="theme-card__name">{t.name}</span>
          <div class="theme-card__swatches">
            <span class="theme-card__swatch" style={`background: ${t.bg}`} title="Background"></span>
            <span class="theme-card__swatch" style={`background: ${t.text}`} title="Text"></span>
            <span class="theme-card__swatch" style={`background: ${t.accent}`} title="Accent"></span>
          </div>
        </div>
      ))}
    </div>

    <div class="themes__customizer" data-animate="scale-in" style="--delay: 0.25s">
      <div class="window-chrome">
        <div class="window-chrome-bar">
          <span class="window-dot window-dot--close"></span>
          <span class="window-dot window-dot--minimize"></span>
          <span class="window-dot window-dot--maximize"></span>
        </div>
        <img
          src="/images/theme-customizer.png"
          alt="Theme customizer panel showing color pickers for editor, chrome, and accent colors"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .themes {
    background: var(--dark-bg-deep);
    color: var(--dark-text);
  }

  .themes__title {
    color: var(--dark-heading);
  }

  .themes__subtitle {
    color: var(--dark-muted);
  }

  .themes__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .theme-card {
    text-align: center;
  }

  .theme-preview {
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    height: 140px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 0.75rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .theme-card:hover .theme-preview {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .theme-preview__sidebar {
    width: 28%;
    background: var(--t-sidebar);
    padding: 8px 6px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .theme-preview__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-bottom: 6px;
  }

  .theme-preview__tab {
    height: 6px;
    border-radius: 3px;
    background: var(--t-muted);
    opacity: 0.3;
  }

  .theme-preview__tab.active {
    opacity: 0.7;
    background: var(--t-accent);
  }

  .theme-preview__editor {
    flex: 1;
    background: var(--t-bg);
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .theme-preview__line {
    height: 4px;
    border-radius: 2px;
    background: var(--t-text);
    opacity: 0.2;
  }

  .theme-preview__line.heading {
    height: 6px;
    width: 50%;
    background: var(--t-accent);
    opacity: 0.8;
    margin-bottom: 2px;
  }

  .theme-preview__code {
    background: var(--t-code);
    border-radius: 4px;
    padding: 6px 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .theme-preview__line.code-line {
    background: var(--t-accent);
    opacity: 0.3;
  }

  .theme-card__name {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--dark-heading);
  }

  .theme-card__swatches {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 0.5rem;
  }

  .theme-card__swatch {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.1);
  }

  .themes__customizer {
    max-width: 800px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .themes__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .theme-preview {
      height: 160px;
    }
  }

  @media (min-width: 1024px) {
    .themes__grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }
</style>
