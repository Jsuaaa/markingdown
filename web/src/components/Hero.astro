---
---

<section class="hero">
  <div class="container">
    <div class="hero__content" data-animate>
      <div class="hero__badge">
        <span class="hero__badge-dot"></span>
        v1.0 — Free & Open Source
      </div>
      <h1 class="hero__title">
        Markdown, the way<br />it should look.
      </h1>
      <p class="hero__subtitle">
        A true WYSIWYG editor designed for Claude Code plans.<br class="hide-mobile" />
        No split pane. No preview toggle. Just write.
      </p>
      <div class="hero__actions">
        <a href="#download" class="btn btn--primary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          Download for macOS
        </a>
        <a href="https://github.com/Jsuaaa/markingdown" target="_blank" rel="noopener" class="btn btn--outline">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>

    <div class="hero__screenshot" data-animate="scale-in" style="--delay: 0.2s">
      <div class="window-chrome">
        <div class="window-chrome-bar">
          <span class="window-dot window-dot--close"></span>
          <span class="window-dot window-dot--minimize"></span>
          <span class="window-dot window-dot--maximize"></span>
        </div>
        <img
          src="/images/editor-content.png"
          alt="Markingdown editor showing a formatted markdown document with sidebar tabs, toolbar, and line numbers"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--dark-bg);
    background-image: radial-gradient(ellipse 60% 50% at 50% -10%, rgba(255, 255, 255, 0.06) 0%, transparent 60%);
    color: var(--dark-text);
    padding: 8rem 0 4rem;
    overflow: hidden;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.06);
    color: var(--accent-purple);
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    letter-spacing: 0.01em;
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-purple);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  .hero .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero__title {
    color: #fff;
    margin-bottom: 1.25rem;
  }

  .hero__subtitle {
    color: var(--dark-muted);
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    max-width: 560px;
    margin-bottom: 2.5rem;
  }

  .hide-mobile {
    display: none;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.9375rem;
    transition: all 0.2s;
  }

  .btn--primary {
    background: var(--accent-blue);
    color: var(--dark-bg);
  }

  .btn--primary:hover {
    opacity: 0.85;
  }

  .btn--outline {
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--dark-text);
  }

  .btn--outline:hover {
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.04);
  }

  .hero__screenshot {
    margin-top: 4rem;
    max-width: 960px;
    width: 100%;
  }

  @media (min-width: 640px) {
    .hide-mobile {
      display: inline;
    }

    .hero {
      padding: 10rem 0 5rem;
    }
  }
</style>
