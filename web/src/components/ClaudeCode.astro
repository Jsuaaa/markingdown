---
const features = [
  {
    title: 'ANSI Cleanup',
    description: 'Paste terminal output directly. ANSI escape codes are automatically stripped and normalized.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
  },
  {
    title: 'Plan Detection',
    description: 'Claude Code plans are auto-detected and converted to clean, structured markdown.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 4V2"/><path d="M15 16v-2"/><path d="M8 9h2"/><path d="M20 9h2"/><path d="M17.8 11.8 19 13"/><path d="M15 9h.01"/><path d="M17.8 6.2 19 5"/><path d="M11 6.2 9.7 5"/><path d="M11 11.8 9.7 13"/><path d="m8 2 1.9 1.9"/><circle cx="15" cy="9" r="6" opacity="0"/><path d="M3 21l9-9"/><path d="M12.2 6.2 11 5"/></svg>`,
  },
  {
    title: 'ASCII Table Conversion',
    description: 'Terminal ASCII tables with box-drawing characters are converted to GFM table syntax.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/><path d="M15 3v18"/></svg>`,
  },
  {
    title: 'Drag & Drop',
    description: 'Drop .md, .markdown, or .txt files directly into the editor from your file system.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
  },
];
---

<section id="claude-code" class="claude section">
  <div class="container">
    <div class="claude__layout">
      <div class="claude__text">
        <h2 class="claude__title" data-animate>Built for Claude Code</h2>
        <p class="claude__subtitle" data-animate style="--delay: 0.1s">
          Paste output from Claude Code and watch it transform into beautiful, structured markdown.
        </p>

        <div class="claude__features">
          {features.map((f, i) => (
            <div class="claude-feature" data-animate style={`--delay: ${0.15 + 0.08 * i}s`}>
              <div class="claude-feature__icon" set:html={f.icon} />
              <div>
                <h3 class="claude-feature__title">{f.title}</h3>
                <p class="claude-feature__desc">{f.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="claude__visual" data-animate="scale-in" style="--delay: 0.2s">
        <div class="claude__before-after">
          <div class="claude__panel claude__panel--before">
            <span class="claude__panel-label">Terminal output</span>
            <pre class="claude__code"><code><span class="ansi-dim">╭──────────────────────────╮</span>
<span class="ansi-dim">│</span> <span class="ansi-bold">Plan:</span> Add auth middleware <span class="ansi-dim">│</span>
<span class="ansi-dim">├──────────────────────────┤</span>
<span class="ansi-dim">│</span> <span class="ansi-green">[TODO]:</span> Validate tokens   <span class="ansi-dim">│</span>
<span class="ansi-dim">│</span> <span class="ansi-green">[TODO]:</span> Add rate limiting <span class="ansi-dim">│</span>
<span class="ansi-dim">╰──────────────────────────╯</span></code></pre>
          </div>

          <div class="claude__arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
            </svg>
          </div>

          <div class="claude__panel claude__panel--after">
            <span class="claude__panel-label">Markingdown</span>
            <pre class="claude__code"><code><span class="md-h2">## Add auth middleware</span>

| Task             | Status  |
|------------------|---------|
| Validate tokens  | pending |
| Add rate limiting | pending |</code></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .claude {
    background: var(--dark-bg);
    color: var(--dark-text);
    overflow: hidden;
  }

  .claude__layout {
    display: grid;
    gap: 3rem;
  }

  .claude__title {
    color: #fff;
    margin-bottom: 1rem;
  }

  .claude__subtitle {
    color: var(--dark-muted);
    font-size: 1.125rem;
    margin-bottom: 2rem;
  }

  .claude__features {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .claude-feature {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .claude-feature__icon {
    flex-shrink: 0;
    color: var(--accent-purple);
    margin-top: 2px;
  }

  .claude-feature__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--dark-heading);
    margin-bottom: 0.25rem;
  }

  .claude-feature__desc {
    font-size: 0.9375rem;
    color: var(--dark-muted);
    line-height: 1.5;
  }

  .claude__visual {
    display: flex;
    justify-content: center;
  }

  .claude__before-after {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 480px;
  }

  .claude__arrow {
    display: flex;
    justify-content: center;
    color: var(--accent-purple);
    transform: rotate(90deg);
  }

  .claude__panel {
    border-radius: var(--radius);
    overflow: hidden;
  }

  .claude__panel-label {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .claude__panel--before {
    background: var(--dark-bg-deep);
    border: 1px solid var(--dark-border);
  }

  .claude__panel--before .claude__panel-label {
    background: rgba(255, 255, 255, 0.03);
    color: var(--dark-muted);
    border-bottom: 1px solid var(--dark-border);
  }

  .claude__panel--after {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .claude__panel--after .claude__panel-label {
    background: rgba(255, 255, 255, 0.05);
    color: var(--accent-purple);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .claude__code {
    padding: 1rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    overflow-x: auto;
  }

  .claude__code code {
    white-space: pre;
  }

  .ansi-dim { opacity: 0.4; }
  .ansi-bold { font-weight: 700; color: var(--dark-heading); }
  .ansi-green { color: #9ece6a; }
  .md-h2 { color: var(--accent-blue); font-weight: 700; }

  @media (min-width: 1024px) {
    .claude__layout {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    .claude__before-after {
      flex-direction: column;
    }

    .claude__arrow {
      transform: rotate(90deg);
    }
  }
</style>
