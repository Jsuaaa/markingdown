---
const formats = [
  {
    name: 'Markdown',
    ext: '.md',
    description: 'The universal format. Raw markdown files, always portable.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    name: 'PDF',
    ext: '.pdf',
    description: 'Styled PDF export via Electron\'s native renderer. Print-ready.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15v-2h1.5a1.5 1.5 0 0 1 0 3H9z"/></svg>`,
  },
  {
    name: 'HTML',
    ext: '.html',
    description: 'Self-contained HTML with embedded CSS. Share anywhere.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
  },
  {
    name: 'LaTeX',
    ext: '.tex',
    description: 'Academic-ready export via Pandoc. Perfect for papers and reports.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M8 13h2l2 4 2-4h2"/></svg>`,
  },
];
---

<section id="export" class="export section">
  <div class="container">
    <h2 class="section-title" data-animate>Export anywhere</h2>
    <p class="section-subtitle" data-animate style="--delay: 0.1s">
      Your documents, in the format you need. One click.
    </p>

    <div class="export__grid">
      {formats.map((f, i) => (
        <div class="export-card" data-animate style={`--delay: ${0.1 + 0.08 * i}s`}>
          <div class="export-card__icon" set:html={f.icon} />
          <h3 class="export-card__name">{f.name}</h3>
          <span class="export-card__ext">{f.ext}</span>
          <p class="export-card__desc">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .export {
    background: var(--dark-bg-deep);
    color: var(--dark-text);
  }

  .export__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .export-card {
    padding: 2rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--dark-border);
    text-align: center;
    transition: border-color 0.2s, background 0.2s;
  }

  .export-card:hover {
    border-color: var(--accent-blue);
    background: rgba(122, 162, 247, 0.05);
  }

  .export-card__icon {
    color: var(--accent-blue);
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
  }

  .export-card__name {
    font-size: 1.25rem;
    color: var(--dark-heading);
    margin-bottom: 0.25rem;
  }

  .export-card__ext {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--dark-muted);
    display: block;
    margin-bottom: 1rem;
  }

  .export-card__desc {
    font-size: 0.9375rem;
    color: var(--dark-muted);
    line-height: 1.5;
  }

  @media (min-width: 640px) {
    .export__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .export__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
