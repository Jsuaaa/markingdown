---
---

<section id="download" class="download section">
  <div class="container">
    <div class="download__content" data-animate>
      <img src={`${import.meta.env.BASE_URL}images/icon.png`} alt="Markingdown app icon" class="download__icon" width="80" height="80" loading="lazy" />
      <h2 class="download__title">Ready to write?</h2>
      <p class="download__subtitle">
        Download Markingdown for macOS. Free and open source.
      </p>
      <div class="download__actions">
        <a href="https://github.com/Jsuaaa/markingdown/releases" target="_blank" rel="noopener" class="btn btn--download">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          Download for macOS
        </a>
        <a href="https://github.com/Jsuaaa/markingdown" target="_blank" rel="noopener" class="btn btn--ghost">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View source on GitHub
        </a>
      </div>
      <p class="download__note">Requires macOS 11+. More platforms coming soon.</p>
    </div>
  </div>
</section>

<style>
  .download {
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
    color: #fff;
    text-align: center;
  }

  .download__content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .download__icon {
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.3));
  }

  .download__title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.75rem;
  }

  .download__subtitle {
    font-size: 1.25rem;
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .download__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn--download {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    color: #1a1a1a;
    padding: 0.875rem 2rem;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn--download:hover {
    opacity: 0.9;
  }

  .btn--ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .btn--ghost:hover {
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.06);
  }

  .download__note {
    margin-top: 1.5rem;
    font-size: 0.875rem;
    opacity: 0.7;
  }
</style>
