---
---

<section id="install" class="install section">
  <div class="container">
    <h2 class="section-title install__title" data-animate>Get started in seconds</h2>
    <p class="section-subtitle install__subtitle" data-animate style="--delay: 0.1s">
      Install Markingdown and start writing immediately.
    </p>

    <div class="install__terminal" data-animate="scale-in" style="--delay: 0.15s">
      <div class="install__body">
        <code class="install__command">
          <span class="install__prompt">#</span> Download from GitHub Releases
        </code>
        <a href="https://github.com/Jsuaaa/markingdown/releases" class="install__link" target="_blank" rel="noopener">
          Download DMG
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .install {
    background: var(--dark-bg);
    color: var(--dark-text);
    padding-top: 0;
  }

  .install__title {
    color: var(--dark-heading);
  }

  .install__subtitle {
    color: var(--dark-muted);
  }

  .install__terminal {
    max-width: 560px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    background: #111111;
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }

  .install__body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem;
    gap: 1rem;
  }

  .install__command {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--dark-text);
    white-space: nowrap;
  }

  .install__prompt {
    color: var(--accent-purple);
    font-weight: 700;
    margin-right: 0.25rem;
  }

  .install__link {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent-purple);
    transition: opacity 0.2s;
  }

  .install__link:hover {
    opacity: 0.8;
  }
</style>
