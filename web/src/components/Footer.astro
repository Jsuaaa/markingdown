---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__inner">
      <div class="footer__brand">
        <img src="https://jsuaaa.github.io/markingdown/images/icon.png" alt="Markingdown" width="20" height="20" class="footer__icon" />
        <span>Markingdown</span>
      </div>
      <div class="footer__links-row">
        <a href="https://github.com/Jsuaaa/markingdown" target="_blank" rel="noopener">GitHub</a>
        <a href="https://github.com/Jsuaaa/markingdown/releases" target="_blank" rel="noopener">Releases</a>
        <a href="https://github.com/Jsuaaa" target="_blank" rel="noopener">By Juan Suarez</a>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; {currentYear} Markingdown</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark-bg-deep);
    color: var(--dark-muted);
    padding: 2rem 0 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--dark-text);
  }

  .footer__icon {
    filter: invert(1);
  }

  .footer__links-row {
    display: flex;
    gap: 1.5rem;
  }

  .footer__links-row a {
    font-size: 0.875rem;
    color: var(--dark-muted);
    transition: color 0.2s;
  }

  .footer__links-row a:hover {
    color: var(--dark-text);
  }

  .footer__bottom {
    padding-top: 1rem;
    text-align: center;
    font-size: 0.75rem;
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .footer__inner {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    .footer__links-row {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
